# PlatformIO build artifacts
.pio/

# VSCode metadata that platformio regenerates per machine
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# ESP-IDF generated sdkconfig (we commit sdkconfig.defaults only)
sdkconfig
sdkconfig.*
!sdkconfig.defaults

# ESP-IDF component manager
managed_components/
dependencies.lock

# Editor/IDE
.idea/
*.swp
.DS_Store

# Local secrets file (template lives at include/secrets.example.h)
secrets.h
!secrets.example.h

# Stashed-aside copy that tools/release.sh leaves behind if it dies
# between the move-aside and the restore trap (very rare; harmless to nuke)
.secrets.h.release-backup.*

# Release artifacts staged by tools/release.sh -- attached to GitHub releases,
# never committed to the repo
/release/
